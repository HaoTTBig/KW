.quiz-page {
  padding-top: 20rpx;
}

.progress-bar {
  height: 12rpx;
  background: #EEE;
  border-radius: 6rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #CC0000, #FF4444);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}
.progress-text {
  text-align: center;
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
}

.question-card {
  margin-top: 40rpx;
  background: #FFF;
  border-radius: 24rpx;
  padding: 48rpx 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}
.q-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
  text-align: center;
  margin-bottom: 40rpx;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.option-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 16rpx;
  transition: all 0.2s;
}
.option-item.selected {
  border-color: #CC0000;
  background: #FFF0F0;
}
.option-label {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #666;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.option-item.selected .option-label {
  background: #CC0000;
  color: #FFF;
}
.option-text {
  font-size: 28rpx;
  color: #333;
}

.next-btn {
  margin-top: 48rpx;
}
.next-btn.disabled {
  opacity: 0.4;
  pointer-events: none;
}
