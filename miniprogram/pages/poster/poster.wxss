.poster-page {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.canvas-wrap {
  width: 650rpx;
  height: 1040rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(139, 0, 0, 0.3);
  margin-bottom: 36rpx;
}
.poster-canvas {
  width: 750rpx;
  height: 1200rpx;
  transform: scale(0.867);
  transform-origin: top left;
}

.actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
