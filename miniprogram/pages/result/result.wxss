.result-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 40rpx;
}

.result-card {
  width: 100%;
  background: linear-gradient(170deg, #CC0000, #8B0000);
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  color: #FFF;
  text-align: center;
  box-shadow: 0 16rpx 48rpx rgba(139, 0, 0, 0.3);
  position: relative;
  overflow: hidden;
}
.result-card::before {
  content: "";
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 215, 0, 0.1);
  border-radius: 50%;
}

.level-badge {
  font-size: 80rpx;
  line-height: 1;
}
.level-title {
  font-size: 48rpx;
  font-weight: 900;
  margin-top: 20rpx;
  color: #FFD700;
  letter-spacing: 4rpx;
}
.level-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

.percentage-wrap {
  margin: 40rpx 0 32rpx;
}
.percentage-num {
  font-size: 96rpx;
  font-weight: 900;
  color: #FFD700;
  line-height: 1;
}
.percentage-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 8rpx;
}

.main-text {
  font-size: 26rpx;
  line-height: 2;
  text-align: left;
  padding: 0 12rpx;
  white-space: pre-line;
}

.roast {
  margin-top: 32rpx;
  padding: 20rpx 28rpx;
  background: rgba(255, 215, 0, 0.15);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #FFD700;
  font-weight: 600;
  text-align: center;
}

.tip {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  font-style: italic;
}

.actions {
  margin-top: 48rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.actions .btn-red {
  background: linear-gradient(135deg, #CC0000, #8B0000);
}
