.index-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
}

.badge-wrap {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #CC0000, #8B0000);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(204, 0, 0, 0.25);
}
.badge {
  font-size: 100rpx;
  line-height: 1;
}

.title {
  font-size: 52rpx;
  font-weight: 900;
  color: #CC0000;
  margin-top: 40rpx;
  letter-spacing: 4rpx;
}
.subtitle {
  font-size: 24rpx;
  color: #8B0000;
  margin-top: 8rpx;
  letter-spacing: 6rpx;
  text-transform: uppercase;
}

.desc {
  margin-top: 48rpx;
  font-size: 28rpx;
  color: #555;
  text-align: center;
  line-height: 2;
  padding: 0 40rpx;
}

.stats {
  display: flex;
  gap: 80rpx;
  margin: 60rpx 0;
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-num {
  font-size: 44rpx;
  font-weight: 900;
  color: #CC0000;
}
.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.btn-red {
  width: 80%;
}


.footer-links {
  margin-top: 32rpx;
}
.link {
  font-size: 22rpx;
  color: #999;
  text-decoration: underline;
}
